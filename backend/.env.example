# 大模型 API Key (使用 OpenAI 或兼容的 API，如阿里云百炼兼容模式)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云百炼 API Key (用于 DashScope Embedding 模型等)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 数据库连接 (默认使用 SQLite 替代 MySQL，方便本地测试)
DATABASE_URL=sqlite:///./ecommerce_ai.db

# 是否在「库中没有任何用户」时自动写入演示订单数据（Docker 首次部署默认需要）。设为 false 可关闭
# SEED_DEMO_ON_EMPTY=true

# Docker Compose：compose 里会通过 environment 覆盖为 sqlite_data 卷路径，一般无需改此项。
# 若自行写 Dockerfile 运行（不用 compose），可把库文件放到目录卷并设为：
# DATABASE_URL=sqlite:////app/sqlite_data/ecommerce_ai.db

# --- 生产环境高并发架构预留配置示例 ---
# DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_ai
# REDIS_URL=redis://localhost:6379/0
